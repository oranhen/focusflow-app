# Copy this file to `.env.local` and fill in the real values from your Supabase project.
# NEVER commit .env.local.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# DO NOT add the Gemini API key here.
# It lives only as a Supabase Edge Function secret, set via:
#   supabase secrets set GEMINI_API_KEY=...
